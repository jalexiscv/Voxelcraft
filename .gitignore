# Material archivado de terceros: NO redistribuir (ver nota legal del README).
# Estas carpetas viven solo en la copia local; no forman parte de VoxelCraft.
/example/
/assets/

# Overrides locales del usuario (assets del juego original u otros propios):
# jamás se distribuyen con el repo; el motor solo los sondea en runtime.
/sounds/
/models/
/textures/

# Herramientas internas de agentes y protocolos de trabajo (no se publican)
/.claude/
/CLAUDE.md
/documents/Protocols/
/.hermes/

# Dependencias del servidor multijugador (npm)
/server/node_modules/

# Configuración local con credenciales: JAMÁS al repositorio.
# api/config.php lleva las credenciales de BD y el secreto compartido del
# servidor; .vscode/ incluye el sftp.json del despliegue.
/api/config.php
/.vscode/

# Respaldo local del proyecto (81 MB): no forma parte del repo
/Minecraft.zip

# Sistema operativo
Thumbs.db
Desktop.ini
.DS_Store
